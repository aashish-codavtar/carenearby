{
  "framework": null,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "admin/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin", "status": 302, "headers": { "Location": "/admin/" } },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
