# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Docker Compose:   mongodb://mongo:27017/carenearby
# Local dev:        mongodb://localhost:27017/carenearby
# MongoDB Atlas:    mongodb+srv://<user>:<pass>@cluster.mongodb.net/carenearby
MONGODB_URI=mongodb://mongo:27017/carenearby

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret_64chars

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_MINUTES=5

# ─── Pricing (CAD per hour) ───────────────────────────────────────────────────
HOURLY_RATE=25

# ─── Service radius (km) ──────────────────────────────────────────────────────
NEARBY_RADIUS_KM=15

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production set to your frontend domain, e.g. https://admin.carenearby.ca
# Native app (Expo Go / production app) doesn't enforce CORS, so * is fine for MVP
CORS_ORIGIN=*

# ─── Stripe (CAD payments) ────────────────────────────────────────────────────
# Replace with live key when ready to charge real cards
STRIPE_SECRET_KEY=sk_test_placeholder

# ─── API Base URL (for document URLs) ─────────────────────────────────────────
# Used for generating full URLs for uploaded documents
API_BASE_URL=http://localhost:3000
